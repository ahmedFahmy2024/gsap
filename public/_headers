# Cache policy (Netlify / Cloudflare Pages — design §11 Phase 6).
# Vite fingerprints everything under /assets/, so those files are immutable
# by construction; the HTML entry must always revalidate so a deploy is
# picked up immediately. Vercel reads vercel.json instead; for nginx/CDN
# equivalents see docs/PHASE_6_HANDOFF.md.

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/og.png
  Cache-Control: public, max-age=86400

/apple-touch-icon.png
  Cache-Control: public, max-age=86400

/favicon.svg
  Cache-Control: public, max-age=86400

/
  Cache-Control: public, max-age=0, must-revalidate

/index.html
  Cache-Control: public, max-age=0, must-revalidate
